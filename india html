<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Count It — World Demographics & Tax Platform</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=DM+Mono:wght@400;500&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:        #0d1f17;
  --bg2:       #122318;
  --bg3:       #1a3025;
  --green:     #1e4d30;
  --green-mid: #2a6b40;
  --green-lite:#3d9e60;
  --accent:    #5ecf82;
  --gold:      #c9a84c;
  --white:     #f4f7f4;
  --cell-bg:   #ffffff;
  --cell-text: #111111;
  --border:    rgba(94,207,130,0.18);
  --muted:     rgba(244,247,244,0.45);
  --shadow:    0 8px 40px rgba(0,0,0,0.5);
  --font-display: 'Cormorant Garamond', Georgia, serif;
  --font-body:    'Outfit', sans-serif;
  --font-mono:    'DM Mono', monospace;
  --nav-h:     64px;
}

html{scroll-behavior:smooth}
body{
  font-family:var(--font-body);
  background:var(--bg);
  color:var(--white);
  min-height:100vh;
  overflow-x:hidden;
}

/* ── SCROLLBAR ── */
::-webkit-scrollbar{width:6px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--green-mid);border-radius:3px}

/* ── NAV ── */
nav{
  position:fixed;top:0;left:0;right:0;z-index:500;
  height:var(--nav-h);
  background:rgba(13,31,23,0.92);
  backdrop-filter:blur(16px);
  border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;
  padding:0 2rem;
}
.nav-logo{
  font-family:var(--font-display);
  font-size:1.8rem;font-weight:700;
  color:var(--white);letter-spacing:-0.5px;
  display:flex;align-items:baseline;gap:0.3rem;
}
.nav-logo span{color:var(--accent);font-size:0.7em;font-family:var(--font-body);
  font-weight:300;letter-spacing:3px;text-transform:uppercase}
.nav-links{display:flex;gap:0.25rem;align-items:center}
.nav-links a{
  color:var(--muted);font-size:0.8rem;font-weight:500;
  letter-spacing:0.5px;text-decoration:none;
  padding:6px 14px;border-radius:8px;
  transition:all 0.2s;
}
.nav-links a:hover{color:var(--accent);background:rgba(94,207,130,0.08)}
.nav-cta{
  background:var(--green-mid);color:var(--white)!important;
  border-radius:8px;padding:7px 18px!important;
  font-weight:600!important;transition:all 0.2s!important;
}
.nav-cta:hover{background:var(--green-lite)!important;color:var(--white)!important}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:8px}
.hamburger span{display:block;width:24px;height:2px;background:var(--white);border-radius:2px;transition:0.3s}

/* ── HERO ── */
.hero{
  min-height:100vh;
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  text-align:center;
  padding:calc(var(--nav-h) + 3rem) 1.5rem 4rem;
  position:relative;
  overflow:hidden;
}
.hero-bg{
  position:absolute;inset:0;
  background:
    radial-gradient(ellipse 80% 60% at 50% 30%, rgba(42,107,64,0.25) 0%, transparent 70%),
    radial-gradient(circle at 20% 80%, rgba(30,77,48,0.3) 0%, transparent 50%),
    radial-gradient(circle at 80% 20%, rgba(94,207,130,0.06) 0%, transparent 40%);
  pointer-events:none;
}
.hero-grid{
  position:absolute;inset:0;
  background-image:
    linear-gradient(rgba(94,207,130,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(94,207,130,0.04) 1px, transparent 1px);
  background-size:60px 60px;
  pointer-events:none;
}
.hero-tag{
  display:inline-flex;align-items:center;gap:0.5rem;
  background:rgba(94,207,130,0.1);border:1px solid rgba(94,207,130,0.3);
  color:var(--accent);font-size:0.72rem;font-weight:600;
  letter-spacing:2px;text-transform:uppercase;
  padding:6px 16px;border-radius:99px;margin-bottom:1.5rem;
  animation:fadeDown 0.8s ease both;
}
.hero-tag::before{content:'';width:6px;height:6px;background:var(--accent);
  border-radius:50%;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.5;transform:scale(0.7)}}

.hero h1{
  font-family:var(--font-display);
  font-size:clamp(3rem, 9vw, 7rem);
  font-weight:700;line-height:0.95;
  color:var(--white);letter-spacing:-2px;
  margin-bottom:1rem;
  animation:fadeUp 0.9s ease 0.1s both;
}
.hero h1 em{color:var(--accent);font-style:italic}
.hero-sub{
  font-size:clamp(0.95rem,2vw,1.15rem);
  color:var(--muted);max-width:560px;line-height:1.7;
  margin:0 auto 2.5rem;
  animation:fadeUp 0.9s ease 0.2s both;
}
.hero-btns{
  display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;
  animation:fadeUp 0.9s ease 0.3s both;
}
.btn-primary{
  background:var(--accent);color:var(--bg);
  font-weight:700;font-size:0.9rem;letter-spacing:0.3px;
  padding:14px 32px;border-radius:12px;
  border:none;cursor:pointer;text-decoration:none;
  transition:all 0.25s;display:inline-flex;align-items:center;gap:0.5rem;
}
.btn-primary:hover{background:#78e09a;transform:translateY(-2px);box-shadow:0 8px 24px rgba(94,207,130,0.35)}
.btn-outline{
  background:transparent;color:var(--white);
  font-weight:500;font-size:0.9rem;
  padding:14px 32px;border-radius:12px;
  border:1.5px solid rgba(255,255,255,0.2);
  cursor:pointer;text-decoration:none;
  transition:all 0.25s;display:inline-flex;align-items:center;gap:0.5rem;
}
.btn-outline:hover{border-color:var(--accent);color:var(--accent);transform:translateY(-2px)}

/* ── STATS ROW ── */
.hero-stats{
  display:flex;gap:2.5rem;justify-content:center;flex-wrap:wrap;
  margin-top:4rem;padding-top:3rem;
  border-top:1px solid var(--border);
  animation:fadeUp 0.9s ease 0.4s both;
  width:100%;max-width:700px;
}
.hero-stat .num{
  font-family:var(--font-mono);font-size:1.8rem;font-weight:500;
  color:var(--accent);display:block;
}
.hero-stat .lbl{font-size:0.72rem;color:var(--muted);letter-spacing:1px;text-transform:uppercase}

@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeDown{from{opacity:0;transform:translateY(-12px)}to{opacity:1;transform:translateY(0)}}

/* ── SECTION ── */
section{padding:5rem 1.5rem;max-width:1200px;margin:0 auto}
.sec-label{
  font-size:0.7rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;
  color:var(--accent);margin-bottom:0.75rem;
}
.sec-title{
  font-family:var(--font-display);font-size:clamp(2rem,5vw,3.5rem);
  font-weight:700;line-height:1.1;color:var(--white);
  margin-bottom:1rem;
}
.sec-sub{color:var(--muted);font-size:0.95rem;line-height:1.7;max-width:560px}

/* ── COUNTRY GRID ── */
#explore{padding-top:2rem}
.country-search{
  width:100%;background:rgba(255,255,255,0.05);
  border:1.5px solid var(--border);border-radius:12px;
  padding:0.85rem 1.25rem;font-family:var(--font-body);font-size:1rem;
  color:var(--white);outline:none;margin-bottom:1.5rem;
  transition:border 0.2s;
}
.country-search::placeholder{color:var(--muted)}
.country-search:focus{border-color:var(--accent)}

.country-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(200px,1fr));
  gap:1rem;
}
.country-card{
  background:var(--bg2);
  border:1px solid var(--border);border-radius:14px;
  padding:1.25rem 1rem;cursor:pointer;
  transition:all 0.25s;display:flex;flex-direction:column;gap:0.5rem;
  text-decoration:none;position:relative;overflow:hidden;
}
.country-card::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(94,207,130,0.07),transparent);
  opacity:0;transition:opacity 0.25s;
}
.country-card:hover{border-color:var(--accent);transform:translateY(-3px);box-shadow:0 12px 32px rgba(0,0,0,0.4)}
.country-card:hover::before{opacity:1}
.country-flag{font-size:2.2rem;line-height:1}
.country-name{font-weight:600;font-size:0.92rem;color:var(--white)}
.country-pop{font-size:0.72rem;color:var(--muted);font-family:var(--font-mono)}
.country-tags{display:flex;gap:0.3rem;flex-wrap:wrap;margin-top:0.25rem}
.ctag{
  font-size:0.6rem;padding:2px 7px;border-radius:99px;
  background:rgba(94,207,130,0.1);color:var(--accent);
  font-weight:600;letter-spacing:0.5px;
}

/* ── FEATURES ── */
.features-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.25rem;margin-top:3rem}
.feat{
  background:var(--bg2);border:1px solid var(--border);border-radius:16px;
  padding:1.75rem;transition:all 0.25s;
}
.feat:hover{border-color:rgba(94,207,130,0.4);transform:translateY(-2px)}
.feat-icon{
  width:48px;height:48px;background:rgba(94,207,130,0.1);border-radius:12px;
  display:flex;align-items:center;justify-content:center;
  font-size:1.4rem;margin-bottom:1rem;
}
.feat h3{font-family:var(--font-display);font-size:1.25rem;font-weight:600;margin-bottom:0.5rem}
.feat p{font-size:0.82rem;color:var(--muted);line-height:1.7}

/* ── COUNTRY PAGE (hidden by default) ── */
#country-page{
  display:none;
  min-height:100vh;
  padding-top:var(--nav-h);
}
#country-page.active{display:block}
#landing{transition:opacity 0.3s}
#landing.hidden{display:none}

/* ── COUNTRY HEADER ── */
.country-hero{
  background:var(--bg2);
  border-bottom:1px solid var(--border);
  padding:2rem 1.5rem;
}
.country-hero-inner{max-width:1200px;margin:0 auto}
.back-btn{
  display:inline-flex;align-items:center;gap:0.4rem;
  color:var(--muted);font-size:0.8rem;cursor:pointer;
  background:none;border:none;padding:0;margin-bottom:1rem;
  transition:color 0.2s;
}
.back-btn:hover{color:var(--accent)}
.country-hero-title{
  display:flex;align-items:center;gap:1rem;flex-wrap:wrap;margin-bottom:1rem;
}
.c-flag{font-size:3rem}
.c-name{font-family:var(--font-display);font-size:2.5rem;font-weight:700;color:var(--white)}
.c-sub{font-size:0.85rem;color:var(--muted);margin-top:0.25rem}
.download-row{display:flex;gap:0.75rem;flex-wrap:wrap;margin-top:1rem}
.dl-btn{
  display:inline-flex;align-items:center;gap:0.4rem;
  background:var(--green);color:var(--white);
  font-size:0.78rem;font-weight:600;letter-spacing:0.5px;
  padding:8px 16px;border-radius:8px;border:1px solid rgba(94,207,130,0.3);
  cursor:pointer;transition:all 0.2s;text-decoration:none;
}
.dl-btn:hover{background:var(--green-mid);border-color:var(--accent)}

/* ── TABS ── */
.page-tabs{
  background:var(--bg2);border-bottom:1px solid var(--border);
  display:flex;overflow-x:auto;padding:0 1.5rem;
}
.page-tabs::-webkit-scrollbar{display:none}
.ptab{
  background:none;border:none;color:var(--muted);
  font-family:var(--font-body);font-size:0.8rem;font-weight:600;
  letter-spacing:0.5px;padding:1rem 1.25rem;
  cursor:pointer;white-space:nowrap;
  border-bottom:2.5px solid transparent;transition:all 0.2s;
}
.ptab:hover{color:var(--white)}
.ptab.active{color:var(--accent);border-bottom-color:var(--accent)}

/* ── SPREADSHEET / DATA TABLES ── */
.data-section{max-width:1200px;margin:0 auto;padding:1.5rem}
.tab-panel{display:none}
.tab-panel.active{display:block}

.panel-head{margin-bottom:1.25rem}
.panel-head h2{font-family:var(--font-display);font-size:1.5rem;color:var(--white);margin-bottom:0.25rem}
.panel-head p{font-size:0.8rem;color:var(--muted)}

/* ── SPREADSHEET TABLE ── */
.sheet-wrap{overflow-x:auto;border-radius:12px;border:1px solid var(--border);margin-bottom:1.5rem}
.sheet{width:100%;border-collapse:collapse}
.sheet thead tr{background:var(--green);color:var(--white)}
.sheet th{
  font-size:0.68rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;
  padding:10px 14px;text-align:left;white-space:nowrap;
  border-right:1px solid rgba(255,255,255,0.1);
}
.sheet th:last-child{border-right:none}
.sheet tbody tr{background:var(--cell-bg)}
.sheet tbody tr:nth-child(even){background:#f5f5f5}
.sheet tbody tr:hover{background:#e8f5ee}
.sheet td{
  font-family:var(--font-mono);font-size:0.82rem;color:var(--cell-text);
  padding:9px 14px;border-right:1px solid #e0e0e0;border-bottom:1px solid #e8e8e8;
  white-space:nowrap;
}
.sheet td:last-child{border-right:none}
.sheet td.editable{cursor:text;position:relative}
.sheet td.editable:focus{
  outline:2px solid var(--accent);outline-offset:-2px;
  background:#fffde7;
}
.sheet td input{
  border:none;background:transparent;font-family:var(--font-mono);
  font-size:0.82rem;color:var(--cell-text);width:100%;outline:none;
  padding:0;
}
.sheet td.bold{font-weight:700}
.sheet td.green{color:#1a6b3c;font-weight:600}
.sheet td.red{color:#c0392b;font-weight:600}
.sheet td.gold{color:#8a5e00}

/* ── IMPORT CALCULATOR ── */
.calc-card{
  background:var(--bg2);border:1px solid var(--border);border-radius:14px;
  padding:1.5rem;margin-bottom:1.5rem;
}
.calc-card h3{font-family:var(--font-display);font-size:1.25rem;color:var(--white);margin-bottom:1rem}
.calc-form{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1rem;margin-bottom:1.25rem}
.cf-group label{
  display:block;font-size:0.68rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;
  color:var(--muted);margin-bottom:0.4rem;
}
.cf-group input,.cf-group select{
  width:100%;background:rgba(255,255,255,0.06);
  border:1.5px solid var(--border);border-radius:8px;
  padding:0.65rem 0.9rem;font-family:var(--font-mono);font-size:0.9rem;
  color:var(--white);outline:none;transition:border 0.2s;
}
.cf-group input::placeholder{color:var(--muted)}
.cf-group input:focus,.cf-group select:focus{border-color:var(--accent)}
.cf-group select option{background:#1a3025;color:var(--white)}
.calc-run{
  background:var(--accent);color:var(--bg);
  font-family:var(--font-body);font-weight:700;font-size:0.9rem;
  padding:11px 28px;border:none;border-radius:10px;cursor:pointer;
  transition:all 0.2s;display:inline-flex;align-items:center;gap:0.4rem;
}
.calc-run:hover{background:#78e09a;transform:translateY(-1px)}

/* ── RESULT CELLS ── */
.result-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:0.75rem;margin-top:1rem}
.rcell{
  background:var(--cell-bg);border-radius:10px;padding:1rem;
  border:1px solid #dde;
}
.rcell-label{font-size:0.65rem;font-weight:700;letter-spacing:0.8px;text-transform:uppercase;color:#888;margin-bottom:0.3rem}
.rcell-value{font-family:var(--font-mono);font-size:1.1rem;font-weight:500;color:var(--cell-text)}
.rcell-value.total{color:#1a6b3c;font-size:1.3rem;font-weight:700}
.rcell-value.red{color:#c0392b}

/* ── HS CODE SEARCH ── */
.hs-search{display:flex;gap:0.75rem;margin-bottom:1rem;flex-wrap:wrap}
.hs-input{
  flex:1;min-width:200px;
  background:rgba(255,255,255,0.06);border:1.5px solid var(--border);
  border-radius:10px;padding:0.75rem 1rem;
  font-family:var(--font-mono);font-size:0.9rem;color:var(--white);outline:none;
  transition:border 0.2s;
}
.hs-input::placeholder{color:var(--muted)}
.hs-input:focus{border-color:var(--accent)}
.hs-btn{
  background:var(--green-mid);color:var(--white);border:none;
  padding:0.75rem 1.25rem;border-radius:10px;font-weight:600;font-size:0.85rem;
  cursor:pointer;transition:all 0.2s;white-space:nowrap;
}
.hs-btn:hover{background:var(--green-lite)}

/* ── INCOME CALCULATOR ── */
.income-calc{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem}
@media(max-width:700px){.income-calc{grid-template-columns:1fr}}

/* ── FOOTER ── */
footer{
  background:var(--bg2);border-top:1px solid var(--border);
  padding:2rem 1.5rem;text-align:center;
  color:var(--muted);font-size:0.75rem;line-height:1.8;
}
footer strong{color:var(--white)}

/* ── MOBILE ── */
@media(max-width:768px){
  .nav-links{display:none;position:fixed;top:var(--nav-h);left:0;right:0;
    background:var(--bg2);border-bottom:1px solid var(--border);
    flex-direction:column;padding:1rem;gap:0.25rem;z-index:400}
  .nav-links.open{display:flex}
  .hamburger{display:flex}
  .hero h1{letter-spacing:-1px}
  .hero-stats{gap:1.5rem}
  .country-grid{grid-template-columns:repeat(auto-fill,minmax(160px,1fr))}
}
@media(max-width:480px){
  .country-grid{grid-template-columns:1fr 1fr}
  nav{padding:0 1rem}
}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-logo">Count It <span>Global</span></div>
  <div class="nav-links" id="navLinks">
    <a href="#explore">Countries</a>
    <a href="#features">Features</a>
    <a href="https://github.com/YOUR_USERNAME/count-it" target="_blank">GitHub</a>
    <a href="#explore" class="nav-cta">Open Data →</a>
  </div>
  <div class="hamburger" onclick="toggleNav()" id="ham">
    <span></span><span></span><span></span>
  </div>
</nav>

<!-- ═══════════════════════════════════════════════ -->
<!-- LANDING PAGE -->
<!-- ═══════════════════════════════════════════════ -->
<div id="landing">

  <!-- HERO -->
  <div class="hero">
    <div class="hero-bg"></div>
    <div class="hero-grid"></div>

    <div class="hero-tag">
      <span></span> Open Data · Real Numbers · Zero Jargon
    </div>

    <h1>Count <em>It.</em></h1>
    <p class="hero-sub">World demographics, income tax, VAT, import costs and trade data — all in one transparent, free platform. Click a country. Get the data. Download it.</p>

    <div class="hero-btns">
      <a href="#explore" class="btn-primary">🌍 Explore Countries</a>
      <a href="https://github.com/YOUR_USERNAME/count-it" class="btn-outline" target="_blank">⭐ Star on GitHub</a>
    </div>

    <div class="hero-stats">
      <div class="hero-stat"><span class="num">195</span><span class="lbl">Countries</span></div>
      <div class="hero-stat"><span class="num">8B+</span><span class="lbl">People Tracked</span></div>
      <div class="hero-stat"><span class="num">50K+</span><span class="lbl">HS Codes</span></div>
      <div class="hero-stat"><span class="num">Free</span><span class="lbl">Always Open</span></div>
    </div>
  </div>

  <!-- FEATURES -->
  <section id="features">
    <div class="sec-label">What's Inside</div>
    <div class="sec-title">Everything in<br><em style="color:var(--accent)">one place.</em></div>
    <div class="features-grid">
      <div class="feat"><div class="feat-icon">👥</div><h3>Demographics</h3><p>Population, birth & death rates, gender split, marriage status, religion, ethnicity — all sourced from official government and UN data.</p></div>
      <div class="feat"><div class="feat-icon">💰</div><h3>Income & Tax</h3><p>Real income data by bracket. Calculate income tax live — change any field and watch the numbers update instantly.</p></div>
      <div class="feat"><div class="feat-icon">📦</div><h3>Import Calculator</h3><p>Enter product name or HS code, price and quantity. Get full breakdown of customs duty, VAT/GST, freight and total landed cost.</p></div>
      <div class="feat"><div class="feat-icon">🚢</div><h3>Freight Costs</h3><p>Sea, air and land freight estimates. Compare cost vs speed for your shipment route.</p></div>
      <div class="feat"><div class="feat-icon">📊</div><h3>Spreadsheet View</h3><p>All data in clean editable cells — like a spreadsheet. Edit income fields, quantities, prices. Download as HTML or plain text.</p></div>
      <div class="feat"><div class="feat-icon">⬇️</div><h3>Download Anything</h3><p>Every country page exports as structured HTML or tab-delimited text. Open in any spreadsheet app instantly.</p></div>
    </div>
  </section>

  <!-- COUNTRY EXPLORER -->
  <section id="explore">
    <div class="sec-label">Country Explorer</div>
