# OS metadata
.DS_Store
Thumbs.db

# IDE / editor files
.vscode/
.idea/
*.swp
*.swo

# Logs and databases
*.log
*.sqlite

# Environment / secrets
.env
.env.local
config.php

# Node modules (if any)
node_modules/

# Python cache (if any)
__pycache__/
*.pyc

# Compiled output
dist/
build/

# Backup files
*.bak
*.backup

# ============================================
# IMPORTANT: Allow data folder and JSON files
# ============================================
# Do NOT ignore the data folder
!data/
# Do NOT ignore JSON files inside data
!data/*.json
